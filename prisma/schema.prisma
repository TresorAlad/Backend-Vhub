// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ORGANIZER
  ADMIN
}

enum Status {
  Active
  Suspended
  Pending
}

model User {
  id            String   @id @default(uuid())
  firebaseId    String   @unique
  email         String   @unique
  name          String?
  organizationName String?
  avatar        String?
  role          Role     @default(USER)
  status        Status   @default(Active)
  bio           String?
  communityDescription String?
  phone         String?
  website       String?
  proofUrl      String?
  pushToken     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizedEvents Event[] @relation("OrganizerEvents")
  participations  Participation[]
  transactions    Transaction[]
  favorites       Favorite[]
  following       Follow[] @relation("UserFollows")
  followers       Follow[] @relation("OrganizerFollowers")
  organizerRequests OrganizerRequest[]
}

enum OrganizerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrganizerRequest {
  id            String   @id @default(uuid())
  userId        String
  status        OrganizerRequestStatus @default(PENDING)
  communityName String
  description   String
  phone         String
  website       String?
  proofUrl      String?
  adminNote     String?
  decidedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

enum EventStatus {
  Live
  Upcoming
  Pending
  Flagged
  Past
  Cancelled
}

enum RegistrationMode {
  Internal
  External
}

enum ParticipationMode {
  Online
  InPlace
}

model Event {
  id                String           @id @default(uuid())
  title             String
  description       String
  date              DateTime
  endDate           DateTime?
  location          String
  latitude          Float?
  longitude         Float?
  imageUrl          String?
  category          String
  status            EventStatus      @default(Upcoming)
  registrationMode  RegistrationMode @default(Internal)
  participationMode ParticipationMode @default(InPlace)
  externalLink      String?
  flagReason        String?
  price             Float            @default(0)
  organizerId       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organizer    User            @relation("OrganizerEvents", fields: [organizerId], references: [id])
  participants Participation[]
  transactions Transaction[]
  favorites    Favorite[]
}

model Participation {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  status    String   @default("REGISTERED") // e.g., REGISTERED, ATTENDED
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Activity {
  id          String   @id @default(uuid())
  type        String   // organizer, event, warning, campaign
  title       String
  description String
  createdAt   DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  eventId     String
  organizerId String
  amount      Float
  status      String   @default("Completed") // Completed, Pending, Refunded
  createdAt   DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id])
  organizer User  @relation(fields: [organizerId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  organizerId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollows", fields: [followerId], references: [id])
  organizer User @relation("OrganizerFollowers", fields: [organizerId], references: [id])

  @@unique([followerId, organizerId])
}
